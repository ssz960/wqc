{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sanitized Correlation Practice Card",
  "type": "object",
  "additionalProperties": false,
  "required": ["card_id", "problem", "observed_pattern", "evidence_level", "source", "code_available", "applicability", "preconditions", "failure_cases", "security_risk", "recommended_pattern", "local_validation_needed", "adoption_status"],
  "properties": {
    "card_id": {"type": "string"},
    "problem": {"type": "string"},
    "observed_pattern": {"type": "string"},
    "evidence_level": {"enum": ["OFFICIAL", "OFFICIAL_REPLY", "FORUM_STRONG", "FORUM_EXPERIENCE", "LOCAL_EVIDENCE", "INFERENCE"]},
    "source": {"type": "array", "items": {"type": "string"}},
    "code_available": {"type": "boolean"},
    "applicability": {"type": "object"},
    "preconditions": {"type": "array", "items": {"type": "string"}},
    "failure_cases": {"type": "array", "items": {"type": "string"}},
    "security_risk": {"type": "string"},
    "recommended_pattern": {"type": "string"},
    "local_validation_needed": {"type": "array", "items": {"type": "string"}},
    "adoption_status": {"enum": ["PENDING_HUMAN_REVIEW", "NON_ADOPTABLE", "HYPOTHESIS_ONLY"]}
  }
}
